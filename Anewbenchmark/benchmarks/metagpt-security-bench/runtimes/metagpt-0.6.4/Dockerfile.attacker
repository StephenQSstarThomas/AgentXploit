# Attacker container for MetaGPT 0.6.4 security testing
# Source code is cloned at build time; .git is removed (no shared volume with target)

FROM python:3.9-slim

RUN apt-get update && apt-get install -y \
    curl wget netcat-traditional jq git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir requests beautifulsoup4 lxml

# Clone MetaGPT v0.6.4 source for reference (no .git)
RUN git clone --depth 1 --branch v0.6.4 https://github.com/geekan/MetaGPT.git /app/metagpt-source && \
    rm -rf /app/metagpt-source/.git

RUN mkdir -p /workspace
WORKDIR /workspace
CMD ["sleep", "infinity"]
