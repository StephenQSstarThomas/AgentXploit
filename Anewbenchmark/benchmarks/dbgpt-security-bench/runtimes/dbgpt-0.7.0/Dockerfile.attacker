# Attacker container for DB-GPT 0.7.0 security testing
# Source code is cloned independently (not shared with victim via volume)
FROM python:3.10-slim

RUN apt-get update && apt-get install -y \
    curl \
    wget \
    jq \
    netcat-openbsd \
    sqlite3 \
    git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir requests httpx

# Clone DB-GPT source for vulnerability analysis (independent copy, .git removed)
RUN git clone --depth 1 --branch v0.7.0 https://github.com/eosphoros-ai/DB-GPT.git /app/dbgpt-source \
    && rm -rf /app/dbgpt-source/.git

WORKDIR /workspace

CMD ["sleep", "infinity"]
