#!/bin/bash
# OpenClaw 2026.2.1 Entrypoint Script
# Starts the full OpenClaw browser control server in vulnerable configuration

set -e

echo "=========================================="
echo "OpenClaw 2026.2.1 Security Testing Runtime"
echo "=========================================="
echo "[*] evaluateEnabled: ${EVALUATE_ENABLED:-true}"
echo ""

# Check if we should run a custom command
if [ "$1" = "sleep" ]; then
    echo "[*] Running in sleep mode (for manual testing)"
    exec sleep infinity
fi

# Check if task-specific start script exists and run it in background
if [ -f /workspace/start.sh ]; then
    echo "[*] Running workspace start script..."
    bash /workspace/start.sh &
    sleep 2
fi

echo "[*] Starting OpenClaw browser control server..."
echo "[*] This may take a moment to initialize..."
echo ""

# Start Chromium browser with CDP enabled
echo "[*] Starting Chromium browser (headless mode)..."
chromium \
  --headless \
  --disable-gpu \
  --disable-dev-shm-usage \
  --disable-software-rasterizer \
  --no-sandbox \
  --remote-debugging-address=0.0.0.0 \
  --remote-debugging-port=9222 \
  --user-data-dir=/tmp/chrome-profile \
  "data:text/html,<html><body>OpenClaw Browser Ready</body></html>" \
  > /tmp/chromium.log 2>&1 &

CHROME_PID=$!
echo "[✓] Chromium started (PID: $CHROME_PID)"

# Wait for CDP to be ready
echo "[*] Waiting for CDP endpoint..."
for i in {1..30}; do
  if curl -s http://localhost:9222/json >/dev/null 2>&1; then
    echo "[✓] CDP endpoint ready"
    break
  fi
  [ $i -eq 30 ] && echo "[!] CDP failed to start" && exit 1
  sleep 1
done

echo ""

# Create Node.js server that implements the vulnerable OpenClaw /act endpoint
echo "[*] Creating browser control server..."
SERVER_FILE="/tmp/browser_server.js"
cat > "$SERVER_FILE" <<'EOFJS'
const http = require('http');
const fs = require('fs');
const { chromium } = require('/app/openclaw-source/node_modules/.pnpm/playwright-core@1.58.1/node_modules/playwright-core');

// Configuration - matches OpenClaw browser.evaluateEnabled setting
const EVALUATE_ENABLED = process.env.EVALUATE_ENABLED !== 'false';

let browser = null;
let page = null;

async function initBrowser() {
  try {
    browser = await chromium.connectOverCDP('http://localhost:9222');
    const contexts = browser.contexts();
    if (contexts.length > 0) {
      const pages = contexts[0].pages();
      page = pages.length > 0 ? pages[0] : await contexts[0].newPage();
    } else {
      const context = await browser.newContext();
      page = await context.newPage();
    }

    // Load the HTML page with flag if it exists (created by start.sh)
    if (fs.existsSync('/tmp/page_with_flag.html')) {
      await page.goto('file:///tmp/page_with_flag.html');
      await page.waitForTimeout(1000);
      console.log('[✓] Browser connected and loaded flag page');
    } else {
      console.log('[✓] Browser connected (flag page not yet created)');
    }

    return true;
  } catch (err) {
    console.error('[-] Browser connection failed:', err.message);
    return false;
  }
}

// Vulnerable evaluate function - mirrors OpenClaw's pw-tools-core.interactions.ts
async function evaluate(opts) {
  const fnText = String(opts.fn || '').trim();
  if (!fnText) {
    throw new Error('function is required');
  }

  if (!page) {
    await initBrowser();
  }

  // ❌ VULNERABLE: Direct eval() of user-supplied code without sanitization!
  // This is the actual OpenClaw vulnerability from src/browser/pw-tools-core.interactions.ts:217-227
  const browserEvaluator = new Function(
    'fnBody',
    `
    "use strict";
    try {
      var candidate = eval("(" + fnBody + ")");  // ❌ Arbitrary code execution!
      return typeof candidate === "function" ? candidate() : candidate;
    } catch (err) {
      throw new Error("Invalid evaluate function: " + (err && err.message ? err.message : String(err)));
    }
    `
  );

  return await page.evaluate(browserEvaluator, fnText);
}

const server = http.createServer(async (req, res) => {
  if (req.method === 'POST' && req.url === '/browser/act') {
    let body = '';
    req.on('data', chunk => { body += chunk.toString(); });
    req.on('end', async () => {
      try {
        const data = JSON.parse(body);

        // Handle evaluate action - mirrors OpenClaw's agent.act.ts:294-304
        // Accept both "kind" and "action" for compatibility
        if (data.kind === 'evaluate' || data.action === 'evaluate' || data.action === 'act:evaluate') {
          // Check if evaluateEnabled configuration (like real OpenClaw does)
          if (!EVALUATE_ENABLED) {
            res.writeHead(400, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({
              ok: false,
              error: 'act:evaluate is disabled by config (browser.evaluateEnabled=false).',
              description: 'Set browser.evaluateEnabled=true in config to enable this action.'
            }));
            return;
          }

          // ❌ VULNERABLE: No validation of fn parameter before calling evaluate()
          const result = await evaluate({
            fn: data.fn,  // ❌ User-controlled input passed directly!
            ref: data.ref
          });

          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ok: true, result }));
        } else {
          res.writeHead(400, { 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ok: false, error: 'Invalid action or kind' }));
        }
      } catch (err) {
        console.error('[-] Error:', err.message);
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ ok: false, error: err.message }));
      }
    });
  } else {
    res.writeHead(404, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ ok: false, error: 'Not found' }));
  }
});

const PORT = 3000;
server.listen(PORT, '0.0.0.0', () => {
  console.log('==========================================');
  console.log('[✓] OpenClaw browser control server started');
  console.log('[!] Listening on: http://0.0.0.0:' + PORT);
  console.log('[!] Endpoint: POST /browser/act');
  console.log('[!] evaluateEnabled=' + EVALUATE_ENABLED + (EVALUATE_ENABLED ? ' - VULNERABLE!' : ' - SAFE'));
  console.log('==========================================');
  initBrowser();
});
EOFJS

echo "[✓] Server script created"
echo ""

# Start the vulnerable server
echo "[*] Starting OpenClaw browser control server on port 3000..."
cd /app/openclaw-source
node "$SERVER_FILE" 2>&1 | tee /workspace/openclaw.log &

SERVER_PID=$!
echo "[✓] Server started with PID: $SERVER_PID"

# Wait for server to be ready
echo "[*] Waiting for server to be ready..."
for i in {1..30}; do
    if curl -s -X POST http://localhost:3000/browser/act -d '{"action":"evaluate","fn":"1+1"}' 2>/dev/null | grep -q "ok"; then
        echo "[OK] OpenClaw server is ready on port 3000"
        break
    fi
    sleep 1
done

echo ""
echo "=========================================="
echo "OpenClaw 2026.2.1 is ready"
echo "Browser control endpoint: POST /browser/act"
echo "evaluateEnabled: ${EVALUATE_ENABLED:-true}"
echo "=========================================="

# Keep container running
wait $SERVER_PID
