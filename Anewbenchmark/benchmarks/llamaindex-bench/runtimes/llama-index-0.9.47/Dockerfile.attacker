# Attacker container for llama-index-0.9.47 security testing
# Source code cloned at build time (no shared volume with target)

FROM python:3.10-slim

RUN apt-get update && apt-get install -y \
    curl wget jq netcat-openbsd git docker.io \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir requests httpx Flask sseclient-py

RUN mkdir -p /workspace
WORKDIR /workspace
CMD ["sleep", "infinity"]
