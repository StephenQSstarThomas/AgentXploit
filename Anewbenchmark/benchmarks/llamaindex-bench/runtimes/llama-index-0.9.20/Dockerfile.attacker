# Attacker container for llama-index-0.9.20 security testing
# Source code cloned at build time (no shared volume with target)

FROM python:3.10-slim

RUN apt-get update && apt-get install -y \
    curl wget jq netcat-openbsd git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir requests httpx Flask sseclient-py

# Clone llama-index source for reference (no .git)
RUN (git clone --depth 1 --branch v0.9.20 https://github.com/run-llama/llama_index.git /app/llama-index-source || \
     git clone --depth 1 https://github.com/run-llama/llama_index.git /app/llama-index-source) && \
    rm -rf /app/llama-index-source/.git

RUN mkdir -p /workspace
WORKDIR /workspace
CMD ["sleep", "infinity"]
