# Attacker container for langchain-exp-0.0.21-vectorsql security testing
# Source code cloned at build time (no shared volume with target)

FROM python:3.9-slim

RUN apt-get update && apt-get install -y \
    curl wget jq netcat-openbsd git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir requests httpx

RUN mkdir -p /workspace
WORKDIR /workspace
CMD ["sleep", "infinity"]
