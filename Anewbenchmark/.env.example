# AgentXploit Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# LLM Model Configuration (used by both agents)
# ============================================================

# Model for the exploiter agent
EXPLOIT_AGENT_MODEL=<your_model_here>
# e.g. EXPLOIT_AGENT_MODEL=claude-sonnet-4-6

# Model for the analysis agent
ANALYSIS_AGENT_MODEL=<your_model_here>
# e.g. ANALYSIS_AGENT_MODEL=claude-sonnet-4-6

# ============================================================
# API Keys
# ============================================================

# OpenAI-compatible API key (required)
OPENAI_API_KEY=<your_openai_api_key_here>

# OpenAI-compatible base URL (if using a proxy or alternative endpoint)
OPENAI_BASE_URL=<your_openai_base_url_here>
# e.g. OPENAI_BASE_URL=https://api.anthropic.com/v1
